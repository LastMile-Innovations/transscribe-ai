# Clerk — optional in dev (keyless mode); set for production or explicit keys
# Use publishable + secret from the same Clerk application (Dashboard → API keys).
# If you use keyless dev (.clerk/), do not set CLERK_SECRET_KEY unless it matches that instance
# or you will see jwk-kid-mismatch at runtime.
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
# CLERK_SECRET_KEY=

# One-time script: pnpm db:backfill-workspace-owners — assigns you as owner on workspaces with zero members (legacy data).
# BOOTSTRAP_CLERK_USER_ID=

# PostgreSQL — Drizzle ORM
# Runtime: lib/db/index.ts (drizzle-orm + postgres.js). Migrations: drizzle.config.ts reads this via dotenv.
# Commands: pnpm db:generate  (SQL from schema)  ·  pnpm db:push  (dev sync)  ·  pnpm db:migrate  (apply drizzle/ migrations)
# Local: create a database, then set a URL like below. Hosted Postgres often needs ?sslmode=require on the URL.
# Railway:
# - DATABASE_URL — on app services in the same project, use the private URL (e.g. postgres.railway.internal) or reference ${{Postgres.DATABASE_URL}} so traffic stays on Railway’s internal network (not DATABASE_PUBLIC_URL / TCP proxy).
# - DATABASE_PUBLIC_URL — TCP proxy host/port (e.g. *.proxy.rlwy.net) for connections from your machine or CI. This app does not read DATABASE_PUBLIC_URL; copy its value into DATABASE_URL in .env.local when developing locally against cloud Postgres.
# - PGHOST/PGPORT etc. in the Railway dashboard are for clients that use libpq-style env vars; PGHOST=postgres.railway.internal does not resolve from your laptop.
# - If connections fail or the host requires TLS, append ?sslmode=require to the URL.
# drizzle-kit loads .env then .env.local (override); DATABASE_URL in .env.local is enough for pnpm db:generate / db:migrate / db:push / db:studio
DATABASE_URL=postgresql://user:password@localhost:5432/transcriptai

# OpenAI — AI assistant (app/api/chat/route.ts) and legal issue digest (app/api/projects/[id]/legal-digest/route.ts)
OPENAI_API_KEY=

# Optional — reserved for future on-screen exhibit OCR (video frames). POST /api/projects/[id]/exhibit-ocr returns 501 until implemented.
# EXHIBIT_OCR_ENABLED=true

# AssemblyAI — transcription (app/api/transcribe)
# How this maps to AssemblyAI’s pre-recorded guide: docs/assemblyai.md
ASSEMBLYAI_API_KEY=
# Optional: set to https://api.eu.assemblyai.com for EU data residency.
# Leave unset to use the default US endpoint.
# ASSEMBLYAI_BASE_URL=https://api.eu.assemblyai.com
# Optional webhook (HTTPS URL of this app): e.g. https://your-app.com/api/webhooks/assemblyai
# AssemblyAI sends POST { transcript_id, status } (completed|error); must return 2xx within ~10s.
# Webhook source IPs (for firewalls): US 44.238.19.20, EU 54.220.25.36.
# When set, submit requests register the webhook; the client still polls but the server can finalize sooner.
# ASSEMBLYAI_WEBHOOK_URL=
# Required in production when WEBHOOK_URL is set (app returns 503 if missing).
# ASSEMBLYAI_WEBHOOK_SECRET=
# Header name AssemblyAI sends with the secret (default X-AssemblyAI-Webhook-Secret).
# ASSEMBLYAI_WEBHOOK_AUTH_HEADER_NAME=

# Object storage — MinIO (Railway) — lib/s3-storage.ts, app/api/upload/route.ts
# Verify: pnpm storage:test (bucket access + presigned PUT/GET + unsigned URL expectation).
# Create bucket: pnpm storage:create-bucket (uses MINIO_BUCKET).
#
# Railway MinIO *service* often defines (reference syntax is Railway-only; it does not work in .env.local):
#   MINIO_BROWSER_REDIRECT_URL="https://${{Console.RAILWAY_PUBLIC_DOMAIN}}"
#   MINIO_PRIVATE_ENDPOINT="http://${{MINIO_PRIVATE_HOST}}:${{MINIO_PRIVATE_PORT}}"
#   MINIO_PRIVATE_HOST="${{RAILWAY_PRIVATE_DOMAIN}}"
#   MINIO_PRIVATE_PORT=9000
#   MINIO_PUBLIC_ENDPOINT="https://${{MINIO_PUBLIC_HOST}}:${{MINIO_PUBLIC_PORT}}"
#   MINIO_PUBLIC_HOST="${{RAILWAY_PUBLIC_DOMAIN}}"
#   MINIO_PUBLIC_PORT=443
#   MINIO_ROOT_USER=…  MINIO_ROOT_PASSWORD=…  PORT="${{MINIO_PRIVATE_PORT}}"
# Add MINIO_BUCKET on that service if you want the template to create it, or create the bucket in the console.
#
# On your *Next.js* service: copy or “Variable Reference” the *resolved* public URL and scoped app credentials.
# Use literal URLs in .env.local — do not paste ${{…}}; Railway expands those only in the dashboard.
# Production note: this repo's Railway `transscribe-ai` service already has `MINIO_PRIVATE_ENDPOINT`
# configured, which keeps server-side SDK traffic on Railway's private network.
# - MINIO_PUBLIC_ENDPOINT = public S3 API (browser + presigned PUTs).
# - MINIO_PRIVATE_ENDPOINT = optional; http://… on Railway private network (same project). Server SDK prefers this; presigns still use public.
# - MINIO_BUCKET = bucket name (e.g. transcriptai).
# - CORS on MinIO: allow your app origin, PUT + Content-Type (and GET for playback / AssemblyAI).
# - Browser playback and AssemblyAI must be able to GET the object URL you hand them.
# - Default app behavior is presigned GETs for browser playback and transcription, which works with private buckets.
# - If you intentionally expose anonymous/public object reads, opt in with:
# MINIO_BROWSER_URL_MODE=public
# MINIO_TRANSCRIPTION_URL_MODE=public
# - Presigned expirations (defaults shown):
# MINIO_UPLOAD_PRESIGN_EXPIRES_SEC=3600
# MINIO_BROWSER_PRESIGN_EXPIRES_SEC=86400
# MINIO_TRANSCRIPTION_PRESIGN_EXPIRES_SEC=172800
# - Multipart uploads for large videos:
# MINIO_MULTIPART_THRESHOLD_MB=64
# MINIO_MULTIPART_PART_SIZE_MB=16
# MINIO_MULTIPART_MAX_PARALLEL_UPLOADS=4
# Part URLs are presigned in batches (initial + POST /api/upload/part-urls) to avoid huge JSON for very large files.
# MINIO_MULTIPART_PRESIGN_BATCH_PARTS=64
# Max parallel video uploads in the library UI (client). Hard-capped in code (see LIBRARY_UPLOAD_CONCURRENCY_HARD_CAP); high values use more CPU/RAM (video preview decode) and bandwidth.
# When unset, defaults scale with navigator.hardwareConcurrency on the client. Network Information API still caps saveData and slow-2g/2g (max 2) and 3g (max 3).
# NEXT_PUBLIC_UPLOAD_MAX_CONCURRENT=12
# - Public mode uses MINIO_PUBLIC_BASE_URL or MINIO_PUBLIC_ENDPOINT + "/" + MINIO_BUCKET.
# - Optional MINIO_PUBLIC_BASE_URL (no trailing slash); else app uses MINIO_PUBLIC_ENDPOINT + "/" + MINIO_BUCKET.
MINIO_PUBLIC_ENDPOINT=
# MINIO_PRIVATE_ENDPOINT=http://minio.railway.internal:9000
# Prefer scoped app credentials; root is kept only as a backwards-compatible fallback.
# MINIO_ACCESS_KEY_ID=
# MINIO_SECRET_ACCESS_KEY=
MINIO_ROOT_USER=
MINIO_ROOT_PASSWORD=
MINIO_BUCKET=
# Optional; default us-east-1 (AWS SDK region for SigV4 against MinIO).
# MINIO_REGION=us-east-1
# MINIO_PUBLIC_BASE_URL=

# Legacy Cloudflare R2 — only used when MINIO_PUBLIC_ENDPOINT is unset.
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=
# R2_PUBLIC_BASE_URL=
